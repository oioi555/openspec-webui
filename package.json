{
  "name": "openspec-webui",
  "version": "0.2.0",
  "description": "Interactive browser UI for OpenSpec-compatible directories",
  "type": "module",
  "bin": {
    "openspec-webui": "./bin/openspec-webui.js"
  },
  "main": "./dist/cli/index.js",
  "scripts": {
    "setup": "npm install --include=dev",
    "setup:dev": "npm run setup",
    "doctor": "node ./scripts/doctor-dev.mjs",
    "doctor:dev": "npm run doctor",
    "dev": "node ./scripts/dev.mjs",
    "debug": "node ./scripts/debug.mjs",
    "release": "node ./scripts/release.mjs",
    "dev:server": "node ./scripts/run-dev-server.mjs",
    "dev:frontend": "node ./scripts/run-dev-frontend.mjs",
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "node ./scripts/run-local-bin.mjs tsc",
    "build:frontend": "node ./scripts/run-local-bin.mjs vite build --config frontend/vite.config.ts",
    "start": "node ./scripts/start.mjs",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx --test src/parser/changes.test.ts frontend/src/stores/theme.test.ts frontend/src/lib/utils.test.ts",
    "test:ui:tabbar": "node ./scripts/test-tabbar-ui.mjs",
    "typecheck": "npm run typecheck:server && npm run typecheck:frontend",
    "typecheck:server": "node ./scripts/run-local-bin.mjs tsc --noEmit",
    "typecheck:frontend": "node ./scripts/run-local-bin.mjs svelte-check --tsconfig ./frontend/tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openspec",
    "viewer",
    "specification",
    "cli",
    "documentation"
  ],
  "author": "oioi555",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oioi555/openspec-webui.git"
  },
  "bugs": {
    "url": "https://github.com/oioi555/openspec-webui/issues"
  },
  "homepage": "https://github.com/oioi555/openspec-webui#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin/",
    "dist/",
    "dist-frontend/"
  ],
  "dependencies": {
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "chokidar": "^4.0.3",
    "commander": "^13.0.0",
    "fastify": "^5.2.1",
    "marked": "^15.0.6",
    "open": "^10.1.0",
    "svelte-sonner": "^1.1.0"
  },
  "devDependencies": {
    "@lucide/svelte": "^1.7.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "bits-ui": "^2.17.2",
    "clsx": "^2.1.1",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.16.1",
    "svelte-check": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  }
}
